{
  "name": "medic",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "lint:packages": "eslint \"packages/**/src/**/*.{ts,tsx}\"",
    "db:generate": "pnpm --filter @medic/database generate",
    "db:migrate": "pnpm --filter @medic/database migrate",
    "db:seed": "pnpm --filter @medic/database seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1"
  },
  "engines": {
    "node": ">=20"
  }
}
