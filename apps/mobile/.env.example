# عنوان الـ API للموبايل (انسخ هذا الملف إلى .env وعدّله).
# بدّل الخادم بتعليق/إلغاء تعليق السطر المناسب — ثم أعد تشغيل Metro: pnpm start --clear
#
# يمكن أن يتضمّن العنوان "/api" أو لا — كلاهما يعمل.
# وإن لم تُحدِّد EXPO_PUBLIC_API_URL إطلاقًا، يشتقّ التطبيق IP جهاز التطوير تلقائيًّا من Metro.

# السيرفر الاصلي (الإنتاج)
EXPO_PUBLIC_API_URL=https://app.faramace.com/api

# للاختبار في السيرفر المحلي
# EXPO_PUBLIC_API_URL=http://192.168.0.172:3000/api
